{
  // C:\ProgramData\KTJ\CDP\appsettings.json파일이 있으면 프로젝트 폴더의 appsettings.json은 무시됩니다.
  // IDE에서 열린 파일은 최초 실행 시 기본값으로만 쓰이고 저장된 이후에는 저장된 파일 사용.

  // Chrome --remote-debugging-port 값과 일치해야 합니다
  "CdpEndpoint": "http://127.0.0.1:9222",

  // true: 앱 시작 시 브라우저 자동 연결
  "AutoConnect": true,

  // 메인 화면에 표시할 버튼 열 수 (1~5)
  "Columns": 1,

  // 버튼 목록
  // - Name        : 버튼 표시 이름
  // - AutoRun     : true면 앱 시작 시 자동으로 해당 탭을 열어 이동
  // - Url         : 클릭 시 이동할 주소
  // - CustomTitle : 탭 제목 앞에 추가할 문자열
  //                 같은 도메인 탭이 여러 개일 때 탭 전환 감지용으로 사용
  //                 비워 두면 실제 페이지 제목 그대로 사용
  // - AutoLogin   : true면 탭 열기 후 자동 로그온 시도
  // - LoginId     : 로그온 아이디   (DPAPI 암호화 저장 — 직접 편집 금지)
  // - LoginPwd    : 로그온 비밀번호 (DPAPI 암호화 저장 — 직접 편집 금지)
  // - IdSelector     : 아이디 입력 필드 CSS 셀렉터    (비워 두면 자동 탐지)
  // - PwdSelector    : 비밀번호 입력 필드 CSS 셀렉터  (비워 두면 자동 탐지)
  // - SubmitSelector : 로그온 버튼 CSS 셀렉터         (비워 두면 자동 탐지)
  // - ExtraInput  : 로그온 전 추가 입력 (예: 단지 선택 드롭다운)
  //     Selector    : CSS 셀렉터
  //     SelectorType: "text"(기본, FillAsync) 또는 "select"(표시 텍스트로 선택)
  //     Value       : 입력할 값 또는 선택할 옵션 표시명
  // - TableSelector : 엑셀 저장 시 사용할 데이터 테이블 CSS 셀렉터 (비워 두면 행이 가장 많은 테이블 자동 선택)
  // - PagingSelector: 페이징 컨테이너 CSS 셀렉터 (비워 두면 id에 Paging 포함된 요소 자동 탐지)
  "Tabs": [
