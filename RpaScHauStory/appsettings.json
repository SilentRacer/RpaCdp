{
  // Chrome --remote-debugging-port 값과 일치해야 합니다
  "CdpEndpoint": "http://127.0.0.1:9222",

  // true: 앱 시작 시 브라우저 자동 연결
  "AutoConnect": true,

  // 메인 화면에 표시할 버튼 열 수 (1~5)
  "Columns": 1,

  // 버튼 목록
  // - Name     : 버튼 표시 이름
  // - AutoRun  : true면 자동 연결 후 즉시 해당 탭을 열어 이동
  // - Url      : 클릭 시 이동할 주소
  // - AutoLogin     : true면 탭 열기 후 자동 로그온 시도
  // - LoginId       : 로그온 아이디 (DPAPI 암호화 저장 — 직접 편집 금지)
  // - LoginPwd      : 로그온 비밀번호 (DPAPI 암호화 저장 — 직접 편집 금지)
  // - IdSelector    : 아이디 입력 필드 CSS 셀렉터 (비워 두면 자동 탐지)
  // - PwdSelector   : 비밀번호 입력 필드 CSS 셀렉터 (비워 두면 자동 탐지)
  // - SubmitSelector: 로그온 버튼 CSS 셀렉터 (비워 두면 자동 탐지)
